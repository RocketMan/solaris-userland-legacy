Backport of fixs to build with clang 22

See https://bugzilla.mozilla.org/show_bug.cgi?id=1977771#c1


--- firefox-140.8.0/third_party/rust/bindgen/clang.rs.orig	2026-02-17 13:37:40.000000000 +0000
+++ firefox-140.8.0/third_party/rust/bindgen/clang.rs	2026-03-09 11:12:53.278840281 +0000
@@ -1210,11 +1210,11 @@
 
     /// Get a cursor pointing to this type's declaration.
     pub(crate) fn declaration(&self) -> Cursor {
-        unsafe {
-            Cursor {
-                x: clang_getTypeDeclaration(self.x),
-            }
-        }
+        let decl = Cursor {
+            x: unsafe { clang_getTypeDeclaration(self.x) },
+        };
+        // Prior to clang 22, the declaration pointed to the definition.
+        decl.definition().unwrap_or(decl)
     }
 
     /// Get the canonical declaration of this type, if it is available.
